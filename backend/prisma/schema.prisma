generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Better Auth Models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean  @default(false)
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("user")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  type                  String
  providerId            String    @map("provider")
  accountId             String    @map("providerAccountId")
  password              String?   @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  accessToken           String?   @map("access_token") @db.Text
  accessTokenExpiresAt  Int?      @map("expires_at")
  scope                 String?
  idToken               String?   @map("id_token") @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("account")
}

model Session {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  impersonatedBy String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, token])
  @@map("verification_token")
}

// --- Sicontrola Business Models ---

enum VehicleType {
  CARRO
  ONIBUS
  CAMINHAO
  MAQUINA
}

enum FuelType {
  GASOLINA_COMUM
  GASOLINA_ADITIVADA
  DIESEL_COMUM
  DIESEL_S10
}

enum Department {
  EDUCACAO
  SAUDE
  ADMINISTRACAO
  GOVERNO
}

enum MaintenanceType {
  CORRETIVA
  PREVENTIVA
  PREDITIVA
  PRESCRITIVA
  DETECTIVA
}

model Vehicle {
  id            String       @id @default(cuid())
  chassi        String       @unique
  renavam       String       @unique
  placa         String       @unique
  type          VehicleType
  make          String
  model         String
  year          Int
  color         String
  fuelType      FuelType
  department    Department
  currentKM     Float
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  refuels       Refuel[]
  maintenances  Maintenance[]
  fines         Fine[]
  revisions     Revision[]

  @@map("vehicle")
}

model Driver {
  id            String    @id @default(cuid())
  name          String
  cnh           String    @unique
  category      String
  validity      DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refuels       Refuel[]

  @@map("driver")
}

model Refuel {
  id            String    @id @default(cuid())
  vehicleId     String
  driverId      String
  date          DateTime
  station       String
  fuelType      FuelType
  liters        Float
  totalValue    Float
  currentKM     Float
  createdAt     DateTime  @default(now())

  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id])
  driver        Driver    @relation(fields: [driverId], references: [id])

  @@map("refuel")
}

model Maintenance {
  id            String          @id @default(cuid())
  vehicleId     String
  type          MaintenanceType
  partValue     Float
  partType      String
  date          DateTime
  time          String
  technician    String
  description   String          @db.Text
  createdAt     DateTime        @default(now())

  vehicle       Vehicle         @relation(fields: [vehicleId], references: [id])

  @@map("maintenance")
}

model Part {
  id          String   @id @default(cuid())
  name        String
  category    String
  stock       Int      @default(0)
  minStock    Int      @default(5)
  unitValue   Float
  provider    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("part")
}

model Fine {
  id          String   @id @default(cuid())
  vehicleId   String
  amount      Float
  description String   @db.Text
  date        DateTime
  status      String   @default("PENDENTE") // PENDENTE, PAGO, CANCELADO
  createdAt   DateTime @default(now())

  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  @@map("fine")
}

model Revision {
  id            String   @id @default(cuid())
  vehicleId     String
  description   String   @db.Text
  scheduledDate DateTime
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])

  @@map("revision")
}

